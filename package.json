{
  "name": "tailwind-unwind",
  "version": "0.1.0",
  "description": "Analyze Tailwind CSS class usage patterns in React/Next.js projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tailwind-unwind": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "node bin/index.js analyze",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "react",
    "nextjs",
    "css",
    "analyzer",
    "cli"
  ],
  "author": "AVPletnev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AVPletnev/tailwind-unwind.git"
  },
  "homepage": "https://github.com/AVPletnev/tailwind-unwind#readme",
  "bugs": {
    "url": "https://github.com/AVPletnev/tailwind-unwind/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
